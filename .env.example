# Firebase Configuration
# Create a Firebase project at https://console.firebase.google.com
# Enable Email/Password Authentication
# Copy these values from Project Settings > General > Your apps

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:000000000000

# Without these vars, app uses mock auth automatically:
# admin@healthsync.com / Admin@123
# doctor@healthsync.com / Doctor@123
